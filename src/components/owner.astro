---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
export interface Props {
	owner: CollectionEntry<"owner">;
}

const { owner } = Astro.props;
const { Content } = await render(owner);
---

<article
	class="flex w-full max-w-xl flex-col items-center gap-5 md:max-w-none"
>
	<img
		src={owner.data.image}
		alt={`Retrato de ${owner.data.name}`}
		width="192"
		height="192"
		class="h-44 w-44 shrink-0 rounded-full object-cover ring-1 ring-white/15"
		loading="lazy"
		decoding="async"
	/>

	<div class="flex w-full flex-col items-center gap-2 text-center">
		<h3 class="font-cormorant text-2xl font-normal tracking-tight text-white md:text-3xl">
			{owner.data.name}
		</h3>
		<p
			class="max-w-md text-[0.65rem] font-medium uppercase leading-snug tracking-[0.14em] text-accent-elegant/88"
		>
			{owner.data.rol}
		</p>
	</div>

	<div
		class="owner-md-content w-full max-w-md text-center text-[0.85rem] leading-relaxed text-white/65 [&_p]:text-center [&_strong]:font-semibold [&_strong]:text-white/85 md:max-w-lg"
	>
		<Content />
	</div>
</article>

<style>
	.owner-md-content :global(p) {
		margin-bottom: 1rem;
	}
	.owner-md-content :global(p:last-child) {
		margin-bottom: 0;
	}
</style>

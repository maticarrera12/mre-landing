---
// Bloque CTA con formulario de contacto
---

<section
	class="relative overflow-hidden border-t border-white/5 bg-surface-deep px-6 py-24 text-white md:px-12"
>
	<div
		class="pointer-events-none absolute bottom-0 right-0 h-[400px] w-[400px] rounded-full bg-accent-elegant/8 blur-[120px]"
	>
	</div>

	<div class="relative z-10 mx-auto max-w-7xl">
		<div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
			<div class="group relative aspect-4/5 w-full overflow-hidden rounded bg-neutral-950 sm:aspect-square lg:aspect-4/5">
				<div
					class="absolute inset-0 bg-linear-to-br from-surface-deep via-transparent to-black/30 opacity-10 mix-blend-overlay"
				>
				</div>
				<img
					src="https://hebbkx1anhila5yf.public.blob.vercel-storage.com/_MG_1768-HDR-oNHA43gxDEJ1SmWJOQcuMYQSV33V2t.jpg"
					alt="Estudio MRE Edificio"
					class="h-full w-full object-cover opacity-85 transition duration-700 ease-out group-hover:scale-[1.03] group-hover:opacity-95"
					loading="lazy"
				/>
				<div
					class="pointer-events-none absolute inset-0 bg-linear-to-t from-surface-deep via-transparent to-black/30"
				>
				</div>
			</div>

			<div class="space-y-10">
				<div class="space-y-3">
					<span class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-accent-elegant"
						>Contacto</span
					>
					<h2 class="font-serif text-4xl font-light tracking-tight md:text-5xl">Escríbanos</h2>
					<p class="max-w-md text-sm font-light leading-relaxed text-white/50">
						Estamos aquí para asistirlo. Háganos llegar su consulta y un miembro de nuestro equipo de
						socios le responderá a la brevedad.
					</p>
				</div>

				<form class="space-y-6">
					<div class="space-y-1.5">
						<label for="name" class="text-[10px] font-medium uppercase tracking-widest text-accent-elegant"
							>Nombre Completo</label
						>
						<input
							type="text"
							id="name"
							required
							class="w-full rounded border border-white/5 bg-white/2 p-4 text-sm text-white/90 outline-none transition duration-300 placeholder-white/20 focus:border-accent-elegant/40"
							placeholder="Ej. Juan Pérez"
						/>
					</div>

					<div class="space-y-1.5">
						<label for="email" class="text-[10px] font-medium uppercase tracking-widest text-accent-elegant"
							>Correo Electrónico</label
						>
						<input
							type="email"
							id="email"
							required
							class="w-full rounded border border-white/5 bg-white/2 p-4 text-sm text-white/90 outline-none transition duration-300 placeholder-white/20 focus:border-accent-elegant/40"
							placeholder="juan@empresa.com"
						/>
					</div>

					<div class="space-y-1.5">
						<label for="phone" class="text-[10px] font-medium uppercase tracking-widest text-accent-elegant"
							>Teléfono <span class="font-light text-white/20">(Opcional)</span></label
						>
						<input
							type="tel"
							id="phone"
							class="w-full rounded border border-white/5 bg-white/2 p-4 font-mono text-sm text-white/90 outline-none transition duration-300 placeholder-white/20 focus:border-accent-elegant/40"
							placeholder="+54 11 1234-5678"
						/>
					</div>

					<div class="space-y-1.5">
						<label for="message" class="text-[10px] font-medium uppercase tracking-widest text-accent-elegant"
							>Mensaje o Requerimiento</label
						>
						<textarea
							id="message"
							rows="4"
							required
							class="w-full resize-none rounded border border-white/5 bg-white/2 p-4 text-sm text-white/90 outline-none transition duration-300 placeholder-white/20 focus:border-accent-elegant/40"
							placeholder="Detalle brevemente las necesidades contables o impositivas de su firma..."
						></textarea>
					</div>

					<div class="pt-2">
						<button
							type="submit"
							class="w-full cursor-pointer rounded bg-accent-elegant py-4 text-xs font-semibold uppercase tracking-widest text-black shadow-xl transition duration-300 hover:bg-accent-elegant-soft"
						>
							Enviar Mensaje
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</section>

---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

export interface Props {
	service: CollectionEntry<"services">;
}

const { service } = Astro.props;
const { Content } = await render(service);

const icon = service.data.icon?.trim();
const iconBaseForExt = icon?.split("?")[0] ?? "";
const iconLooksLikeImg =
	Boolean(icon) && /\.(svg|png|webp|jpg|jpeg)$/i.test(iconBaseForExt);
/** Rutas en `public` (`/assets/...`) o URL absoluta a una imagen */
const iconIsImgSrc =
	iconLooksLikeImg &&
	Boolean(icon) &&
	(icon!.startsWith("/") || /^https?:\/\//i.test(icon!));

---

<article
	class="service-card group relative overflow-hidden bg-surface-warm p-2 shadow-sm backdrop-blur-sm md:p-4 before:pointer-events-none before:absolute before:left-0 before:top-0 before:z-10 before:h-full before:w-[3px] before:origin-top before:scale-y-0 before:bg-accent-elegant before:transition-transform before:duration-500 before:ease-[cubic-bezier(0.22,1,0.36,1)] before:content-[''] hover:before:scale-y-100 motion-reduce:before:transition-none"
>
	<header class="relative z-20 flex flex-col items-start gap-4 md:gap-5">
		<div class="flex w-full flex-row items-center justify-between gap-4">
			<div
				class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-accent-elegant/15 text-accent-elegant md:h-14 md:w-14"
				aria-hidden="true"
			>
				{
					iconIsImgSrc ? (
						<img
							src={icon}
							alt=""
							class="h-7 w-7 object-contain md:h-8 md:w-8"
							loading="lazy"
						/>
					) : (
						<span class="select-none text-2xl md:text-[1.75rem]">
							{icon ?? "📄"}
						</span>
					)
				}
			</div>
			<div>
				<span class="text-8xl font-cormorant tracking-tight text-accent-elegant opacity-45 transition-opacity duration-420 ease-out group-hover:opacity-100 motion-reduce:transition-none">
					{service.data.order_label ?? service.data.order}
				</span>
			</div>
		</div>
		<div class="min-w-0 flex-1">
			<h3
				class="text-xl font-semibold font-cormorant tracking-tight text-white md:text-4xl"
			>
				{service.data.title}
			</h3>
			<p
				class="mt-3 text-[0.9rem] leading-relaxed text-white/62 md:text-[0.95rem]"
			>
				{service.data.description}
			</p>
		</div>
	</header>

	{
		(service.body ?? "").trim().length > 0 && (
			<div class="relative z-20 mt-6 border-t border-white/8 pt-6 text-[0.85rem] leading-relaxed text-white/58 [&_p:not(:last-child)]:mb-4 [&_strong]:font-semibold [&_strong]:text-white/78">
				<Content />
			</div>
		)
	}
</article>

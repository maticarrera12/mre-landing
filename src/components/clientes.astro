---
import { Star } from "@lucide/astro";
import TestimonialsSlider from "./testimonials-slider.astro";
---

<main
	id="clientes"
	class="min-h-screen bg-surface-deep px-8 py-16 md:px-10 md:py-24 lg:px-14"
>
	<div
		class="mx-auto flex max-w-6xl flex-col gap-12 md:flex-row md:items-stretch md:gap-0"
	>
		<div
			class="flex min-h-0 w-full shrink-0 flex-col items-start self-stretch text-left md:w-[35%] md:pr-8 lg:pr-10"
		>
			<h4
				class="text-[1rem] font-semibold uppercase tracking-[0.16em] text-accent-elegant/85"
			>
				Opiniones de clientes
			</h4>

			<h2
				class="mt-3 text-fluid-display font-cormorant tracking-tight text-white"
			>
				Lo que dicen quienes
				<span class="font-light italic text-accent-elegant">confían</span>
				en nosotros.
			</h2>

			<div
				class="mt-8 flex w-full flex-wrap items-end justify-start gap-x-3 gap-y-2 md:mt-auto md:pt-10"
				aria-label="Valoración en Google"
			>
				<span
					class="font-cormorant text-9xl leading-none tracking-tight text-accent-elegant tabular-nums"
					>4.8</span
				>
				<div
					class="flex items-center gap-0.5 text-accent-elegant"
					aria-hidden="true"
				>
					<Star class="size-8 fill-accent-elegant stroke-accent-elegant" />
					<Star class="size-8 fill-accent-elegant stroke-accent-elegant" />
					<Star class="size-8 fill-accent-elegant stroke-accent-elegant" />
					<Star class="size-8 fill-accent-elegant stroke-accent-elegant" />
					<Star class="size-8 fill-accent-elegant stroke-accent-elegant" />
				</div>
			</div>
		</div>

		<div
			class="hero-column-divider relative z-20 hidden md:block"
			aria-hidden="true"
		>
		</div>

		<div
			class="flex min-h-0 min-w-0 w-full flex-1 flex-col self-stretch text-left md:min-h-0 md:pl-8 lg:pl-10"
		>
			<div class="flex min-h-0 w-full min-w-0 flex-1 flex-col items-stretch">
				<TestimonialsSlider />
			</div>
		</div>
	</div>
</main>

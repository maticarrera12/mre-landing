---
import Header from '../components/header.astro';
import '../styles/global.css';
import {ClientRouter} from 'astro:transitions';
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Estudio MRE | Profesionales en Ciencias Económicas y Financieras</title>
	</head>
	<body class="font-montserrat bg-surface-deep text-white antialiased">
		<Header />
		<main>
			<slot />
		</main>
	</body>
	<ClientRouter />
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background-color: var(--surface-deep, #0d0d0d);
	}
</style>
